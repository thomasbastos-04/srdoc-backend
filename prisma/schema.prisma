generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  passwordHash      String
  // Campos para futuro:
  // phone          String?  
  // twoFAEnabled   Boolean  @default(false)
  // biometricId    String?  // referenciar template biométrico
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
